# Required — OpenAI API key for the LLM judge (gpt-4o-mini) and Khora's
# extraction/embedding pipeline. The benchmark will refuse to start without it.
OPENAI_API_KEY=sk-...

# --- Optional overrides --------------------------------------------------------
# If you want to run the benchmark against your own Postgres or Neo4j (rather
# than the docker-compose stack `make setup` spins up), point these at it.
# Both default to the compose stack at localhost.

# POSTGRES_URL=postgresql://bench:bench@localhost:5432/khora_graphrag_bench
# NEO4J_URL=bolt://neo4j:benchbench@localhost:7687
#
# If those default ports clash with something already running locally, remap
# just the port — both the docker-compose container and the connection URL pick
# these up (example values; defaults are 5432 / 7687):
# POSTGRES_PORT=5433
# NEO4J_BOLT_PORT=7688

# --- Khora version override ---------------------------------------------------
# By default the benchmark pins `khora[accel]==0.21.0`. Override to validate
# against a different release.
#
# Example: validate against an older release:
#   KHORA_SPEC="khora[accel]==0.20.0" make setup
#
# Example: install from a git ref (testing an unreleased fix):
#   KHORA_SPEC="khora[accel] @ git+https://github.com/DeytaHQ/khora.git@main" make setup
#
# KHORA_SPEC=khora[accel]==0.21.0

# --- Concurrency tuning -------------------------------------------------------
# Number of documents the Khora adapter ingests concurrently. Default 10 is
# tuned for typical developer machines. Push up to 16-20 on bigger boxes;
# reduce to 4 if you see "Transaction failed and will be retried" deadlock
# warnings in Neo4j during ingestion.
#
# KGB_MAX_CONCURRENT_DOCUMENTS=10
#
# Number of questions answered concurrently in the query phase (default 5).
# Caps the OpenAI request burst; raise it to shorten the query phase (the run's
# longest, API-bound stretch). Only affects wall-clock, never results. Back off
# if OpenAI returns 429s. Also settable per-run: make run-full QUERY_CONCURRENCY=25
# KGB_QUERY_CONCURRENCY=5

# --- Neo4j memory -------------------------------------------------------------
# The Neo4j container's heap + page cache. Defaults (2G each) beat the tiny
# image defaults that cause cold-cache graph queries to hit khora's 5s
# transaction timeout. Raise on bigger boxes; keep low on small Docker VMs.
#
# NEO4J_HEAP_SIZE=2G
# NEO4J_PAGECACHE_SIZE=2G
